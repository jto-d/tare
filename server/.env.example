# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Session cookie signing secret (generate with `openssl rand -hex 32`)
SESSION_SECRET=replace-me-with-a-long-random-string

# Google OAuth 2.0 credentials — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where the server listens
PORT=3001

# Where the client runs (used for post-login redirect + CORS in prod)
CLIENT_URL=http://localhost:5173
